# ─────────────────────────────────────────────────────────────────────────────
# A Thousand Lamps — Environment Variable Reference
# Copy to .env.local for local development. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB — local Docker auth
MONGO_USER=admin
MONGO_PASSWORD=change_this
# Local dev URI (Docker Compose)
MONGODB_URI=mongodb://admin:change_this@mongo:27017/athousandlamps?authSource=admin
# Production Atlas URI
# MONGODB_URI=mongodb+srv://ahmedrumman_db_user:<db_password>@cluster0.shlzrko.mongodb.net/athousandlamps

# Admin auth — single token for the site maintainer (MVP)
ADMIN_SECRET_TOKEN=change_this_to_a_secure_random_string

# Cloudinary — image upload and CDN
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Facebook JS SDK — required for fb-post embeds to render
# Create an app at https://developers.facebook.com → My Apps → Add App (Website type)
# Then add your Vercel domain under App Domains + add the Facebook Login product
NEXT_PUBLIC_FACEBOOK_APP_ID=

# Public app config (prefixed with NEXT_PUBLIC_ — exposed to browser)
NEXT_PUBLIC_SITE_URL=https://athousandlamps.org
NEXT_PUBLIC_APP_NAME=A Thousand Lamps
